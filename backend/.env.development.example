# ===========================================
# DESENVOLVIMENTO LOCAL - NUNCA use produção
# ===========================================
# Copie para .env ou .env.development e preencha.
# Banco: use PostgreSQL local ou projeto Supabase DEV separado.

APP_ENV=development
NODE_ENV=development

# Banco (OBRIGATÓRIO: localhost ou projeto dev Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/aurix_dev?schema=public"

# JWT (use um secret diferente de produção)
JWT_SECRET="dev-secret-change-in-production"
JWT_EXPIRES_IN=7d

PORT=3001
FRONTEND_URL="http://localhost:5173"
