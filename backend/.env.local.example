# ===========================================
# DESENVOLVIMENTO LOCAL - Cópia para .env.local
# ===========================================
# Este arquivo NUNCA deve conter credenciais de produção.
# Localhost deve usar APENAS banco local ou projeto Supabase de desenvolvimento.

APP_ENV=development
NODE_ENV=development

# Obrigatório em dev: localhost ou banco de desenvolvimento
DATABASE_URL="postgresql://user:password@localhost:5432/aurix_dev?schema=public"

# Supabase: se "Can't reach database server" com host db.<ref>.supabase.co:5432, a rede pode não
# rotear IPv6. Use Transaction pooling no painel (IPv4): porta 6543, host aws-0-<região>.pooler.supabase.com,
# usuário postgres.<ref> (não só "postgres"). Exemplo de formato:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

JWT_SECRET="dev-secret-min-32-chars-for-local-only"
JWT_EXPIRES_IN=7d

PORT=3001
FRONTEND_URL="http://localhost:5173"
